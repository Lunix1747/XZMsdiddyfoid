local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")
local changeSetting = rs:WaitForChild("rE"):WaitForChild("ChangeSetting")

-- State tracking
local isInvincible = false
local lastInvincibilityTime = 0
local INVINCIBILITY_COOLDOWN = 5 -- seconds

local function fireInv(state)
	if state ~= isInvincible or (tick() - lastInvincibilityTime > INVINCIBILITY_COOLDOWN) then
		changeSetting:FireServer("Invincibility", state)
		isInvincible = state
		lastInvincibilityTime = tick()
	end
end

-- Optimized invincibility function
local function ensureInvincibility()
	-- Only fire if not already invincible or if cooldown has passed
	if not isInvincible or (tick() - lastInvincibilityTime > INVINCIBILITY_COOLDOWN) then
		fireInv(true)
	end
end

-- Initial invincibility setup
task.spawn(function()
	task.wait(2)
	fireInv(false)
	task.wait(0.2)
	fireInv(true)
end)

-- Handle respawn
lp.CharacterAdded:Connect(function(character)
	task.wait(1)
	ensureInvincibility()
end)

-- Start with invincibility
ensureInvincibility()

-- Rest of your script with optimizations
local humanPass = lp:WaitForChild("Passes"):WaitForChild("Human")
local crushers = workspace:WaitForChild("Crushers")
local list = {}
local index = 1

local function isValid(v)
	return v and v.Parent and v:IsA("BoolValue") and v.Name == "KillHumans"
end

local function refreshList()
	list = {}
	for _, v in ipairs(crushers:GetDescendants()) do
		if isValid(v) then
			table.insert(list, v)
		end
	end
end

-- Initial population
refreshList()

-- Listen for new KillHumans values added
crushers.DescendantAdded:Connect(function(v)
	if isValid(v) then
		table.insert(list, v)
	end
end)

-- Handle removal
crushers.DescendantRemoving:Connect(function(v)
	if isValid(v) then
		for i, listItem in ipairs(list) do
			if listItem == v then
				table.remove(list, i)
				if index > #list then
					index = 1
				end
				break
			end
		end
	end
end)

-- Combined loop for human pass and crusher management
task.spawn(function()
	while task.wait(1) do
		-- Keep Human pass ON
		humanPass.Value = true
		
		-- Check invincibility status periodically
		ensureInvincibility()
		
		-- Cycle through and disable KillHumans values
		if #list > 0 then
			if index > #list then
				index = 1
			end
			
			local v = list[index]
			if isValid(v) then
				v.Value = false
				-- Set Dismember IntValue to 0
				local dismember = v:FindFirstChild("Dismember")
				if dismember and dismember:IsA("IntValue") then
					dismember.Value = 0
				end
			else
				-- Remove invalid entries
				table.remove(list, index)
				if index > #list and #list > 0 then
					index = 1
				end
			end
			
			index += 1
		end
	end
end)
